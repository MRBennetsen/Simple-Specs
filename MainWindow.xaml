<Window x:Class="Simple_Specs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple-Specs" Height="750" Width="1150"
        Background="Transparent" Foreground="White"
        WindowStyle="None" 
        AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Storyboard x:Key="GlowAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="15" To="40" Duration="0:0:3" />
            <ColorAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)"
                            From="#00D2FF" To="#8A2BE2" Duration="0:0:6" />
        </Storyboard>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D2FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource GlowAnimation}"/>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="TabButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#050505" CornerRadius="15" BorderBrush="#1A1A1A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseDown">
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" 
                        Foreground="#666" Background="Transparent" BorderThickness="0" FontSize="16" 
                        Cursor="Hand" Click="CloseButton_Click" FontWeight="Bold"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                <TextBlock Text="SIMPLE-SPECS" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#FFFFFF"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Button x:Name="BtnTabSystem" Content="SYSTEMINFO" Style="{StaticResource TabButtonStyle}" Foreground="#00D2FF" Click="SwitchTab_Click"/>
                    <Button x:Name="BtnTabSupport" Content="SUPPORT" Style="{StaticResource TabButtonStyle}" Click="SwitchTab_Click"/>
                </StackPanel>

                <UniformGrid x:Name="TabSystemInfo" Grid.Row="2" Columns="3" VerticalAlignment="Center">
                    <Border x:Name="SystemCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                        <StackPanel Margin="20">
                            <TextBlock Text="SYSTEM" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="SystemText" Text="..." Margin="0,15,0,0" FontSize="16" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="CPU" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="CpuText" Text="..." Margin="0,15,0,0" FontSize="16" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="GPU" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="GpuText" Text="..." Margin="0,15,0,0" FontSize="16" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="RAM" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="RamText" Text="..." Margin="0,15,0,0" FontSize="16" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LAGER" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0" Margin="0,0,0,15"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="StorageText" Text="..." FontSize="15" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="NETVÆRK" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="NetworkText" Text="Klar til at hente..." Margin="0,15,0,15" FontSize="16" TextWrapping="Wrap"/>
                            <Button Content="Hent Netværksinfo" Click="UpdateNetwork_Click" Background="#252525" Foreground="White" BorderThickness="0" Padding="8" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid x:Name="TabSupport" Grid.Row="2" Columns="3" VerticalAlignment="Center" Visibility="Collapsed">
                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="DIAGNOSTIK" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="OsText" Text="Henter OS..." Margin="0,15,0,0" FontSize="16" TextWrapping="Wrap"/>
                            <TextBlock x:Name="UptimeText" Text="Henter oppetid..." Margin="0,10,0,0" FontSize="16" TextWrapping="Wrap" Foreground="#00D2FF"/>
                            
                            <TextBlock x:Name="BatterySupportText" Text="" Margin="0,15,0,0" FontSize="15" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="GRAFIK DRIVER" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock x:Name="DriverText" Text="Henter driver info..." Margin="0,15,0,15" FontSize="15" TextWrapping="Wrap"/>
                            <Button x:Name="BtnUpdateDriver" Content="Søg efter opdatering" Click="UpdateDriver_Click" 
                                    Background="#252525" Foreground="White" BorderThickness="0" Padding="8" Cursor="Hand" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Margin="20">
                            <TextBlock Text="FJERNSTYRING" FontSize="20" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                            <TextBlock Text="Har du brug for hjælp fra IT? Start QuickSupport, så vi kan overtage skærmen." Margin="0,15,0,15" FontSize="15" TextWrapping="Wrap"/>
                            <Button x:Name="BtnTeamViewer" Content="Download &amp; Start TeamViewer" Click="StartTeamViewer_Click" 
                                    Background="#1A1A1A" Foreground="#8A2BE2" BorderBrush="#8A2BE2" BorderThickness="1" Padding="8" Cursor="Hand" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Button x:Name="BtnCopy" Content="Kopier alle specs til udklipsholder" Grid.Row="3" 
                        HorizontalAlignment="Center" Margin="0,20,0,0" Padding="30,12" FontSize="14" FontWeight="Bold"
                        Background="#1A1A1A" Foreground="#00D2FF" BorderBrush="#00D2FF" BorderThickness="1"
                        Cursor="Hand" Click="CopySpecs_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>